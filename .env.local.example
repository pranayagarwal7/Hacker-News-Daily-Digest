# Required — get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — enables rate limiting on /api/ask (20 req/user/hour)
# Get from https://upstash.com/ — free tier is sufficient
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Set automatically by Vercel in production. For local dev, leave unset
# (page.tsx falls back to http://localhost:3000 for the ISR digest fetch).
# VERCEL_URL=your-project.vercel.app
